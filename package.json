{
  "name": "vocalflow-windows",
  "version": "1.0.0",
  "description": "VocalFlow for Windows - Voice to Text Desktop App",
  "main": "electron.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "build:next": "next build src/renderer",
    "build:electron": "electron-builder",
    "build": "npm run build:next && npm run build:electron",
    "start": "electron ."
  },
  "keywords": [
    "voice",
    "speech-to-text",
    "electron",
    "windows"
  ],
  "author": "Sahil Bharat Arate",
  "license": "MIT",
  "devDependencies": {
    "@types/electron": "^1.4.38",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "ts-node": "^10.9.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.vocalflow.windows",
    "productName": "VocalFlow",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "@deepgram/sdk": "^5.0.0",
    "dotenv": "^17.4.1",
    "groq-sdk": "^1.1.2",
    "mic": "^2.1.2",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uiohook-napi": "^1.5.5"
  }
}
